# React 19.0.0 is pinned but @azure/msal-react@5.3.1's peer range starts at
# 19.2.1. The runtime works fine — both are 19.x and React's 19.0 → 19.2
# changes don't affect MSAL's usage. legacy-peer-deps lets `npm ci` install
# without rejecting the apparent peer-range mismatch.
#
# Remove this once we bump react to ^19.2.0 (or @azure/msal-react relaxes
# its peer range — they often do in patch releases).
legacy-peer-deps=true
