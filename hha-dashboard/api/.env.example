# HHA Dashboard API · environment template
#
# Copy to `.env` for local dev. Never commit a real .env. In production these
# values come from Azure App Service application settings + Key Vault refs
# (see `docs/RUNBOOK.md`).

# ---------- Runtime ----------
ENV=dev
LOG_LEVEL=INFO

# ---------- Web origin (CORS) ----------
# Empty in dev — main.py falls back to localhost. In prod Bicep emits the App
# Service URL into App Settings, so this is auto-populated there.
WEB_ORIGIN=

# ---------- Database ----------
# Local docker-compose Postgres defaults. Override per-env in production.
DATABASE_URL=postgresql+asyncpg://hha:hha@localhost:5432/hha_dashboard
DATABASE_URL_SYNC=postgresql+psycopg://hha:hha@localhost:5432/hha_dashboard

# ---------- Azure Entra ID (dashboard auth) ----------
# Empty triggers the dev-stub: `Authorization: Dev <role>` is accepted in
# place of a real Entra JWT. See app/deps.py::get_current_user.
AZURE_TENANT_ID=
AZURE_API_CLIENT_ID=
AZURE_API_SCOPE=

ENTRA_GROUP_ADMIN=
ENTRA_GROUP_EXEC=
ENTRA_GROUP_COMP_VIEWER=
ENTRA_GROUP_OWNER_OPS=
ENTRA_GROUP_OWNER_FINANCE=
ENTRA_GROUP_OWNER_CLINICAL=
ENTRA_GROUP_OWNER_HR=

# ---------- Census portal (Phase 1) ----------
# Default email for the single shared portal credential. The actual login
# (and any rotation) lives in the `auth.census_credentials` table — seeded
# by `scripts/seed_census_credential.py`. NEVER set the password here:
# the hash lives only in the DB.
CENSUS_PORTAL_EMAIL=portal@hhamedicine.com
# CENSUS_PORTAL_PASSWORD_HASH is intentionally NOT supported as an env var.
# To set or rotate the password, run:
#   bash infra/census_seed.sh --email portal@hhamedicine.com --password '<strong>'
# That script writes the argon2id hash to auth.census_credentials.

# ---------- Azure Blob Storage (uploads + backups) ----------
# Dev defaults to Azurite. Prod uses Managed Identity — leave the conn string blank.
AZURE_STORAGE_ACCOUNT_URL=http://localhost:10000/devstoreaccount1
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_UPLOADS_CONTAINER=uploads
AZURE_STORAGE_BACKUPS_CONTAINER=backups

# ---------- Azure Document Intelligence (PDF extract) ----------
# Empty disables the PDF-extract path — see services/pdf_extract.py.
AZURE_DOC_INTELLIGENCE_ENDPOINT=
AZURE_DOC_INTELLIGENCE_API_KEY=

# ---------- Upload limits ----------
UPLOAD_MAX_BYTES=26214400  # 25 MB

# ---------- Email (Azure Communication Services) ----------
# Empty disables outbound email (the alert digest cron then exits 0).
AZURE_COMMUNICATION_ENDPOINT=
AZURE_COMMUNICATION_SENDER=
AZURE_COMMUNICATION_CONNECTION_STRING=

# ---------- Paycom (workforce sync, gated on vendor unblock) ----------
# Empty triggers the no-op stub in jobs/paycom_sync.
PAYCOM_API_BASE_URL=
PAYCOM_CLIENT_ID=
PAYCOM_CLIENT_SECRET=

# ---------- Application Insights / OpenTelemetry ----------
# Empty disables telemetry. Connection string from monitor.bicep output.
APPLICATIONINSIGHTS_CONNECTION_STRING=
