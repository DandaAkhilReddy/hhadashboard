{# Ventra ingest quarantine — V1-V11 / V13 failure. Sent to ops list. #}
<!doctype html>
<html lang="en">
  <body style="margin:0;padding:0;background:#f5f6fa;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;color:#1f2937;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f5f6fa;padding:24px 0;">
      <tr>
        <td align="center">
          <table role="presentation" width="600" cellspacing="0" cellpadding="0" style="background:#ffffff;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden;">
            <tr>
              <td style="padding:24px 28px;border-bottom:1px solid #fef3c7;background:linear-gradient(135deg,#d97706,#f59e0b);color:#ffffff;">
                <div style="font-size:14px;letter-spacing:0.05em;text-transform:uppercase;opacity:0.9;">HHA Ventra ingest · ACTION REQUIRED</div>
                <div style="font-size:22px;font-weight:600;margin-top:4px;">Drop quarantined — {{ drop_date }}</div>
              </td>
            </tr>
            <tr>
              <td style="padding:24px 28px;">
                <p style="margin:0 0 16px 0;font-size:14px;color:#4b5563;">
                  A Ventra drop failed validation and was moved to quarantine. <strong>No data was written</strong> to the fact tables for this drop. The original files remain in vendor-inbound for replay after correction.
                </p>

                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-bottom:14px;border:1px solid #fef3c7;border-left:4px solid #f59e0b;border-radius:8px;background:#fffbeb;">
                  <tr>
                    <td style="padding:14px 16px;">
                      <div style="font-size:11px;letter-spacing:0.05em;text-transform:uppercase;color:#92400e;font-weight:700;">
                        Rule {{ rule }}
                      </div>
                      <div style="font-size:14px;color:#374151;margin-top:6px;">{{ message }}</div>
                    </td>
                  </tr>
                </table>

                {% if details %}
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-bottom:14px;border:1px solid #e5e7eb;border-radius:8px;">
                  <tr><td style="padding:12px 16px;font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-weight:600;border-bottom:1px solid #f3f4f6;">Details</td></tr>
                  {% for k, v in details.items() %}
                  <tr><td style="padding:8px 16px;font-size:13px;border-bottom:1px solid #f3f4f6;">
                    <span style="color:#6b7280;">{{ k }}</span>
                    <span style="float:right;font-family:monospace;color:#374151;">{{ v }}</span>
                  </td></tr>
                  {% endfor %}
                </table>
                {% endif %}

                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-bottom:14px;font-size:13px;color:#6b7280;">
                  <tr><td style="padding:4px 0;">Run ID</td><td style="padding:4px 0;font-family:monospace;color:#374151;">{{ run_id }}</td></tr>
                  <tr><td style="padding:4px 0;">Correlation ID</td><td style="padding:4px 0;font-family:monospace;color:#374151;">{{ correlation_id }}</td></tr>
                </table>

                <p style="margin:16px 0 8px 0;font-size:14px;color:#1f2937;font-weight:600;">Next steps</p>
                <ol style="margin:0 0 0 18px;padding:0;font-size:13px;color:#4b5563;line-height:1.6;">
                  <li>Review reject sidecar: <code style="background:#f3f4f6;padding:1px 4px;border-radius:3px;font-size:12px;">vendor-quarantine/ventra/{{ drop_date }}/_REJECT_REASON.txt</code></li>
                  <li>Email Ventra with the rule + details above; ask for a corrected file</li>
                  <li>When the corrected file arrives, upload to <code style="background:#f3f4f6;padding:1px 4px;border-radius:3px;font-size:12px;">vendor-inbound/ventra/{{ drop_date }}-retry-1/</code></li>
                  <li>Runbook: <a href="https://github.com/DandaAkhilReddy/hhadashboard/blob/main/hha-dashboard/docs/04-operations/RUNBOOK.md#ventra-quarantine" style="color:#4338ca;">docs/04-operations/RUNBOOK.md#ventra-quarantine</a></li>
                </ol>
              </td>
            </tr>
            <tr>
              <td style="padding:18px 28px;border-top:1px solid #fef3c7;background:#fafafa;font-size:12px;color:#6b7280;">
                Sent automatically by the Ventra ingest job. Quarantined drops are retained 90 days then auto-deleted by lifecycle policy.
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
