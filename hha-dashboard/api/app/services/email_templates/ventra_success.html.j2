{# Ventra ingest success — sent to Crystal + Akhil per ALERT_EMAIL_TO_OPS. #}
<!doctype html>
<html lang="en">
  <body style="margin:0;padding:0;background:#f5f6fa;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;color:#1f2937;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f5f6fa;padding:24px 0;">
      <tr>
        <td align="center">
          <table role="presentation" width="600" cellspacing="0" cellpadding="0" style="background:#ffffff;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden;">
            <tr>
              <td style="padding:24px 28px;border-bottom:1px solid #d1fae5;background:linear-gradient(135deg,#059669,#10b981);color:#ffffff;">
                <div style="font-size:14px;letter-spacing:0.05em;text-transform:uppercase;opacity:0.85;">HHA Ventra ingest</div>
                <div style="font-size:22px;font-weight:600;margin-top:4px;">Drop processed — {{ drop_date }}</div>
              </td>
            </tr>
            <tr>
              <td style="padding:24px 28px;">
                <p style="margin:0 0 16px 0;font-size:14px;color:#4b5563;">
                  Ventra delivery for {{ drop_date }} ingested cleanly. The finance dashboard tiles refresh automatically within ~5 minutes.
                </p>

                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-bottom:14px;border:1px solid #e5e7eb;border-radius:8px;">
                  <tr><td style="padding:12px 16px;font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;font-weight:600;border-bottom:1px solid #f3f4f6;">Summary</td></tr>
                  {% for table, count in rows_by_table.items() %}
                  <tr><td style="padding:10px 16px;font-size:14px;border-bottom:1px solid #f3f4f6;">
                    <span style="color:#6b7280;">{{ table }}</span>
                    <strong style="float:right;color:#111827;">{{ count }} rows</strong>
                  </td></tr>
                  {% endfor %}
                  <tr><td style="padding:10px 16px;font-size:14px;background:#f9fafb;">
                    <span style="color:#6b7280;">Total rows written</span>
                    <strong style="float:right;color:#059669;">{{ rows_written }}</strong>
                  </td></tr>
                </table>

                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-bottom:14px;font-size:13px;color:#6b7280;">
                  <tr><td style="padding:4px 0;">Run ID</td><td style="padding:4px 0;font-family:monospace;color:#374151;">{{ run_id }}</td></tr>
                  <tr><td style="padding:4px 0;">Correlation ID</td><td style="padding:4px 0;font-family:monospace;color:#374151;">{{ correlation_id }}</td></tr>
                  <tr><td style="padding:4px 0;">Duration</td><td style="padding:4px 0;color:#374151;">{{ duration_seconds }}s</td></tr>
                  {% if vendor_source_systems %}
                  <tr><td style="padding:4px 0;">Source systems</td><td style="padding:4px 0;color:#374151;">{{ vendor_source_systems|join(', ') }}</td></tr>
                  {% endif %}
                </table>

                <p style="margin:16px 0 0 0;font-size:13px;color:#6b7280;">
                  Dashboard: <a href="https://pulse.hhamedicine.com/boards/finance" style="color:#4338ca;text-decoration:none;">pulse.hhamedicine.com/boards/finance</a>
                </p>
              </td>
            </tr>
            <tr>
              <td style="padding:18px 28px;border-top:1px solid #d1fae5;background:#fafafa;font-size:12px;color:#6b7280;">
                Sent automatically by the Ventra ingest job. No action required.
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
