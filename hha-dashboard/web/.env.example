# =============================================================================
# Frontend env vars — copy to .env.local (NOT committed) for local development
# =============================================================================
#
# Anything prefixed with NEXT_PUBLIC_ is inlined into the client bundle at
# build time. Keep secrets server-only — SESSION_SECRET is the only secret
# in this file and it is read only by Node-runtime route handlers.

# ----------------------------------------------------------------------------
# Auth mode
# ----------------------------------------------------------------------------
# `dev`: skip MSAL entirely; api-client falls back to "Authorization: Dev
#        admin"; middleware lets every request through; /api/auth/me returns
#        a placeholder shape. Local dev with the FastAPI dev stub.
#
# `prod` (or anything other than `dev`): require a sign-in flow. Middleware
#        redirects to /auth/sign-in when the hha_session cookie is absent.
NEXT_PUBLIC_AUTH_MODE=dev

# ----------------------------------------------------------------------------
# Entra ID (Microsoft / Azure AD) — only needed when AUTH_MODE != dev
# ----------------------------------------------------------------------------
# Tenant + the two app registrations from docs/ENTRA_SETUP.md.
NEXT_PUBLIC_AZURE_TENANT_ID=
NEXT_PUBLIC_AZURE_WEB_CLIENT_ID=
NEXT_PUBLIC_AZURE_API_CLIENT_ID=

# Group object IDs that map to role names in the UI. Mirror of the API's
# ENTRA_GROUP_* env vars (without NEXT_PUBLIC_). The frontend uses these
# only for *display* — the backend re-checks every request.
NEXT_PUBLIC_ENTRA_GROUP_ADMIN=
NEXT_PUBLIC_ENTRA_GROUP_EXEC=
NEXT_PUBLIC_ENTRA_GROUP_COMP_VIEWER=
NEXT_PUBLIC_ENTRA_GROUP_OWNER_OPS=
NEXT_PUBLIC_ENTRA_GROUP_OWNER_FINANCE=
NEXT_PUBLIC_ENTRA_GROUP_OWNER_CLINICAL=
NEXT_PUBLIC_ENTRA_GROUP_OWNER_HR=

# ----------------------------------------------------------------------------
# Session cookie encryption — REQUIRED outside dev
# ----------------------------------------------------------------------------
# 32-byte AES-GCM key, base64-encoded. Generate with:
#   openssl rand -base64 32
# Rotating this invalidates every active session — users will be forced to
# re-sign-in. In prod, source from Key Vault, never from a literal env file.
SESSION_SECRET=

# ----------------------------------------------------------------------------
# Backend
# ----------------------------------------------------------------------------
# FastAPI base URL the frontend calls. In docker-compose dev: http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
