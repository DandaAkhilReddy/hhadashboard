# ============================================================================
# HHA Dashboard — env.example
# Copy to `.env` and fill in. Never commit `.env`.
# In Azure, all of these come from Key Vault via Managed Identity (not env).
# ============================================================================

# ---- Environment ----
ENV=dev                                          # dev | staging | prod
LOG_LEVEL=INFO                                   # DEBUG (dev only) | INFO | WARNING | ERROR

# ---- Database ----
# Local dev: points to docker-compose postgres
# Prod: Azure Database for PostgreSQL via private endpoint (pulled from Key Vault)
DATABASE_URL=postgresql+asyncpg://hha:hha@localhost:5432/hha_dashboard
DATABASE_URL_SYNC=postgresql://hha:hha@localhost:5432/hha_dashboard  # alembic uses sync

# ---- Entra ID (Microsoft identity) ----
# From the api app registration in your Entra tenant
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_API_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_API_CLIENT_SECRET=                          # prod uses managed identity; dev only
AZURE_API_SCOPE=api://{api-client-id}/access_as_user

# Web app registration
NEXT_PUBLIC_AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
NEXT_PUBLIC_AZURE_WEB_CLIENT_ID=00000000-0000-0000-0000-000000000000
NEXT_PUBLIC_AZURE_API_SCOPE=api://{api-client-id}/access_as_user
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ---- Entra security group IDs (for role mapping) ----
# Output of `az ad group show --group HHA-Dashboard-<Role>`
ENTRA_GROUP_ADMIN=
ENTRA_GROUP_EXEC=
ENTRA_GROUP_COMP_VIEWER=
ENTRA_GROUP_OWNER_OPS=
ENTRA_GROUP_OWNER_FINANCE=
ENTRA_GROUP_OWNER_CLINICAL=
ENTRA_GROUP_OWNER_HR=

# ---- Azure resources (prod; Managed Identity reads Key Vault for these) ----
AZURE_KEY_VAULT_URL=https://kv-hha-dashboard-dev.vault.azure.net/
AZURE_STORAGE_ACCOUNT=sthhadashboarddev
AZURE_STORAGE_BACKUPS_CONTAINER=backups
AZURE_STORAGE_VENTRA_DROPS_CONTAINER=ventra-raw-drops
AZURE_STORAGE_UPLOADS_CONTAINER=uploads

# ---- Blob Storage (Session 3 uploads pipeline) ----
# Dev: Azurite emulator in docker-compose (connection string includes canonical dev account + key)
# Prod: DefaultAzureCredential + Managed Identity — omit connection string entirely
AZURE_STORAGE_ACCOUNT_URL=http://localhost:10000/devstoreaccount1
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://localhost:10000/devstoreaccount1;

# ---- Azure Document Intelligence (census PDF extraction) ----
# Dev: provision a throwaway Cognitive Services resource + API key
# Prod: Managed Identity — omit the API key
AZURE_DOC_INTELLIGENCE_ENDPOINT=https://<your-di-resource>.cognitiveservices.azure.com/
AZURE_DOC_INTELLIGENCE_API_KEY=

# ---- Azure Communication Services (email) ----
ACS_CONNECTION_STRING=                            # local dev uses mailpit; ACS for prod
ACS_SENDER_ADDRESS=donotreply@hhamedicine.com

# ---- App Insights ----
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ---- Ventra (P2+) ----
# Populated once Ventra confirms access path
VENTRA_ACCESS_MODE=                               # sftp | api | manual_csv_upload
VENTRA_SFTP_HOST=
VENTRA_SFTP_USERNAME=
VENTRA_SFTP_KEY_PATH=
VENTRA_API_BASE_URL=
VENTRA_API_CLIENT_ID=
VENTRA_API_CLIENT_SECRET=

# ---- Paycom (P1+) ----
# Populated once Paycom provisions API access (4-6 weeks typical)
PAYCOM_API_BASE_URL=https://api.paycomonline.net
PAYCOM_CLIENT_ID=
PAYCOM_CLIENT_SECRET=
PAYCOM_CLIENT_CODE=                               # HHA's Paycom client code

# ---- FMV benchmark source ----
# Paid MGMA data OR public HRSA/Medicare PFS proxy
FMV_BENCHMARK_SOURCE=mgma_im_hospitalist_50th
FMV_BENCHMARK_USD=258000                          # override in DB per physician

# ---- Alert thresholds ----
ALERT_FL_COLLECTIONS_DAILY_TARGET=147727
ALERT_TX_COLLECTIONS_DAILY_TARGET=22500
ALERT_FL_COLLECTIONS_MTD_TARGET=3250000
ALERT_AR_OVER_120_PCT_THRESHOLD=15                # red if > this
ALERT_COLLECTIONS_PCT_OF_TARGET_THRESHOLD=90      # red if < this
ALERT_DAYS_IN_AR_THRESHOLD=45
ALERT_CREDENTIAL_URGENT_DAYS=30
ALERT_CREDENTIAL_WARNING_DAYS=60
ALERT_CREDENTIAL_INFO_DAYS=90

# ---- Local dev only (docker-compose) ----
POSTGRES_USER=hha
POSTGRES_PASSWORD=hha
POSTGRES_DB=hha_dashboard
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
